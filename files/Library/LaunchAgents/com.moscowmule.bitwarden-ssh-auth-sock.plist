<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.moscowmule.bitwarden-ssh-auth-sock</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>/bin/launchctl setenv SSH_AUTH_SOCK "$HOME/.bitwarden-ssh-agent.sock"</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
